# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Runner (apps/runner) =====
RUNNER_PORT=4000
RUNNER_WORKSPACE_ROOT=./.runner-workspaces
RUNNER_API_TOKEN=replace-with-random-64-char-token
RUNNER_DATABASE_URL=postgres://cchub:cchub@localhost:5433/cchub

# ===== Budget Hard Cap (per user / per day, USD) =====
DAILY_BUDGET_USD=20
MONTHLY_BUDGET_USD=300

# ===== Session limits =====
MAX_PARALLEL_SESSIONS=3
MAX_TURNS_PER_SESSION=50
SESSION_TIME_LIMIT_SECONDS=1800
TOOL_RESULT_MAX_BYTES=524288
SSE_EVENT_MAX_BYTES=262144

# ===== Langfuse (self-hosted) =====
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ===== Web (apps/web) =====
NEXT_PUBLIC_RUNNER_URL=http://localhost:4000
NEXT_PUBLIC_LANGFUSE_URL=http://localhost:3100
